{
  "Database": {
    "Enabled": false,
    "ConnectionString": "Server=.;Database=TEST;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "WebApi": {
    "Enabled": true,
    "BaseUrl": "http://localhost:7001",
    "Endpoint": "/api/excel-import"
  },
  "StartWithWindows": false,
  "LogDirectory": "Logs",
  "Templates": [
    {
      "Name": "RowTemplate",
      "Enabled": true,
      "WatchPath": "D:\\ExcelImport\\ExcelData\\Row",
      "IncludeSubdirectories": true,
      "IntervalMinutes": 3,
      "TemplateFile": "row-template.json",
      "TargetTable": "dbo.ExcelImportRow",
      "FilePattern": "*.xlsx"
    },
    {
      "Name": "CellTemplate",
      "Enabled": true,
      "WatchPath": "D:\\ExcelImport\\ExcelData\\Cell",
      "IncludeSubdirectories": true,
      "IntervalMinutes": 3,
      "TemplateFile": "cell-template.json",
      "TargetTable": "dbo.ExcelImportCell",
      "FilePattern": "*.xlsx"
    }
  ]
}
